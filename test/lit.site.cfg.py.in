# Taken from mlir test folder(https://github.com/llvm/llvm-project/blob/main/mlir/test/) and modified as required
@LIT_SITE_CFG_IN_HEADER@

config.llvm_tools_dir = lit_config.substitute("@LLVM_TOOLS_DIR@")
config.python_executable = "@Python3_EXECUTABLE@"
config.enable_python_bindings = @DataflowSchedulerDialects_ENABLE_PYTHON_BINDINGS@
config.python_package_install_prefix = "@MLIR_BINDINGS_PYTHON_INSTALL_PREFIX@"
config.dataflow_scheduler_obj_root = "@DataflowSchedulerDialects_BINARY_DIR@"
config.dataflow_scheduler_tools_dir = "@LLVM_RUNTIME_OUTPUT_INTDIR@"
config.llvm_shlib_ext = "@SHLIBEXT@"

import lit.llvm
lit.llvm.initialize(lit_config, config)

# Let the main config do the real work.
lit_config.load_config(config, "@DataflowSchedulerDialects_SOURCE_DIR@/test/lit.cfg.py")
