@PACKAGE_INIT@

#
# Exported targets
#

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

#
# Umbrella targets
#

if(NOT TARGET dataflow-scheduler-dialects-capi)
  add_custom_target(dataflow-scheduler-dialects-capi)
endif()
if(NOT TARGET dataflow-scheduler-dialects-doc)
  add_custom_target(dataflow-scheduler-dialects-doc)
endif()
if(NOT TARGET dataflow-scheduler-dialects-headers)
  add_custom_target(dataflow-scheduler-dialects-headers)
endif()

#
# Exported variables
#

set(DataflowSchedulerDialects_ENABLE_PYTHON_BINDINGS @DataflowSchedulerDialects_ENABLE_PYTHON_BINDINGS@)

set(DataflowSchedulerDialects_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")

set_property(GLOBAL PROPERTY DataflowSchedulerDialects_DIALECT_LIBS "@DataflowSchedulerDialects_DIALECT_LIBS@")
set_property(GLOBAL PROPERTY DataflowSchedulerDialects_CONVERSION_LIBS "@DataflowSchedulerDialects_CONVERSION_LIBS@")
set_property(GLOBAL PROPERTY DataflowSchedulerDialects_EXTENSION_LIBS "@DataflowSchedulerDialects_EXTENSION_LIBS@")
set_property(GLOBAL PROPERTY DataflowSchedulerDialects_TRANSLATION_LIBS "@DataflowSchedulerDialects_TRANSLATION_LIBS@")

check_required_components(@PROJECT_NAME@)
